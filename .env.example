# E-commerce platform environment (copy to .env).
# docker compose reads these via ${VAR:-default}.

# MUST be changed before any real deployment
JWT_SECRET=dev-secret-change-me

# Per-service Postgres (compose maps each to its own DB container)
POSTGRES_USER=ecom
POSTGRES_PASSWORD=ecom_pass

# Optional integrations (leave blank => safe mock mode)
STRIPE_API_KEY=
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Where notifications are sent when an event lacks the user's email
DEFAULT_NOTIFY_EMAIL=
DEFAULT_NOTIFY_PHONE=

# Event bus: rabbitmq (docker) or memory (native dev)
EVENT_BUS=rabbitmq
RABBITMQ_URL=amqp://guest:***@rabbitmq:5672/

# ---------------------------------------------------------------------------
# Render deployment (render.yaml) — set these as Render env / secret group
# "ecom-secrets". Render auto-injects RENDER_EXTERNAL_URL; map it to PUBLIC_URL
# so each service registers its real external URL with the discovery registry.
#   PUBLIC_URL        = https://<service>.onrender.com   (or use RENDER_EXTERNAL_URL)
#   DISCOVERY_URL     = https://ecom-discovery.onrender.com
#   JWT_SECRET        = a 32+ char random string (shared by all services)  [SECRET]
#   DATABASE_URL      = optional; defaults to per-service SQLite on the volume
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Firebase Hosting (frontend) — firebase.json serves frontend-react/dist.
# The SPA calls the deployed gateway via VITE_API_BASE at BUILD time:
#   VITE_API_BASE=https://ecom-gateway.onrender.com   npm run build
# No Firebase web config is required because the app authenticates against the
# Render backend, not Firebase Auth.
# ---------------------------------------------------------------------------
